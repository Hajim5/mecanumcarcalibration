void setup() {
    Serial.begin(115200);
    
    // Start library & WiFi
    telemetry.begin();
    
    // Initialize your Keyestudio motor driver pins here...
}

void loop() {
    // 1. Your robot movement/control logic goes here
    // Example: Read line sensors, update motor PWM values, etc.
    
    // 2. Simply feed current robot values to the library function.
    // The library handles its own non-blocking timer internally.
    telemetry.sendTelemetry(speedFL, speedFR, speedRL, speedRR, currentMove, batteryVoltage);
}
